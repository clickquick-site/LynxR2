    "modules": {
        "pos": {
            "quickButtons": true,
            "splitBill": true,
            "discounts": true,
            "serviceCharge": true,
            "multiplePayments": true,
            "refunds": true,
            "cashManagement": true
        },
        "kitchen": {
            "autoAccept": true,
            "printOnAccept": true,
            "voiceAlerts": true,
            "colorCoding": true,
            "prepTimeTracking": true,
            "allergenWarnings": true
